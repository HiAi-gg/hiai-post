{
  "name": "hiai-post",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "app"
  ],
  "scripts": {
    "dev": "bun run --parallel dev:api dev:frontend",
    "dev:api": "cd backend && bun run dev",
    "dev:frontend": "cd app && bun run dev",
    "build": "bun run --filter '*' build",
    "lint": "bun run --filter '*' lint",
    "lint:fix": "bun run --filter '*' lint:fix",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bunx vitest run",
    "db:generate": "cd backend && bun run db:generate",
    "db:migrate": "cd backend && bun run db:migrate",
    "db:push": "cd backend && bun run db:push",
    "db:seed": "cd backend && bun run db:seed",
    "test:coverage": "bunx vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0"
  }
}
