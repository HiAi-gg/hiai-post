# Database
DATABASE_URL=postgresql://hipost:${POSTGRES_PASSWORD:-changeme}@localhost:5436/hiai_post
POSTGRES_USER=hipost
POSTGRES_PASSWORD=your-secure-db-password

# Redis
REDIS_URL=redis://localhost:6383

# Auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string-min
BETTER_AUTH_URL=http://localhost:50300
HIAI_ADMIN_JWT_SECRET=  # HS256 shared secret with hiai-admin proxy; required when serving behind the unified host
OAUTH_STATE_SECRET=  # Optional; if unset, derived from BETTER_AUTH_SECRET (signed OAuth state)

# Encryption (32+ char hex key for AES-256-GCM — generate with: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key-here-generate-with-openssl-rand-hex-32

# Social Platform API Keys
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
THREADS_APP_ID=
THREADS_APP_SECRET=
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Mastra / LLM
OPENROUTER_API_KEY=
OPENAI_API_KEY=  # Required for DALL·E 3 (image-gen.ts); falls back to placehold.co when unset
MASTRA_MODEL=openai/gpt-4o

# Web search (Tavily) — https://tavily.com — optional; web-search tool returns empty results when unset
TAVILY_API_KEY=

# MinIO (shared)
MINIO_ENDPOINT=localhost
MINIO_PORT=9010
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=hiai-post
MINIO_USE_SSL=false

# Webhook (hiai-store integration)
HIAI_STORE_WEBHOOK_SECRET=  # Required to accept POST /api/v1/webhooks/store-product; HMAC SHA-256 of body

# Error tracking
SENTRY_DSN=  # Sentry-compatible DSN via hiai-observe; leave empty to disable

# Ports
API_PORT=50300
FRONTEND_PORT=50301

# Environment
NODE_ENV=development
