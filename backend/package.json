{
  "name": "hiai-post-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/api/index.ts",
    "build": "bun build src/api/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "elysia": "^1.4.28",
    "@elysiajs/cors": "^1.4.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5",
    "zod": "^3.24.0",
    "ioredis": "^5.6.0",
    "minio": "^8.0.0",
    "sharp": "^0.33.0",
    "better-auth": "^1.6.0",
    "@better-auth/drizzle-adapter": "^1.6.0",
    "@mastra/core": "^1.36.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
